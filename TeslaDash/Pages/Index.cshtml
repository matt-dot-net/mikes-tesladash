@page
@model IndexModel
@{ ViewData["Title"] = "Garage"; }

@if (Model.Snapshot is not { } snapshot)
{
    <section class="connect card">
        <p class="eyebrow">TESLA FLEET API</p>
        <h1 class="connect-title">Connect your garage</h1>
        <div class="notice warning"><strong>Vehicle data unavailable</strong><p>@Model.Error</p></div>
        <a class="tesla-button" asp-page="/Connect">Open Tesla connection</a>
    </section>
}
else
{
    <section class="hero">
        <div><p class="eyebrow">MY GARAGE</p><h1>@snapshot.VehicleName</h1><p class="status"><span></span>@snapshot.ConnectionState</p></div>
        <div class="battery" aria-label="Battery at @snapshot.StateOfCharge percent"><div class="battery-fill" style="width:@snapshot.StateOfCharge%"></div><strong>@snapshot.StateOfCharge%</strong></div>
    </section>
    <section class="metric-grid">
        <article class="card accent-card"><p class="eyebrow">ODOMETER</p><h2>@snapshot.MilesDriven.ToString("N0") mi</h2><p>Current vehicle mileage</p><small>Live Fleet API data</small></article>
        <article class="card"><p class="eyebrow">CHARGING</p>@if(snapshot.ActiveCharge is {} charge){<h2>@charge.RateKw kW</h2><p>@charge.AddedKwh kWh added · @charge.MinutesRemaining min remaining</p><div class="progress"><i style="width:@snapshot.StateOfCharge%"></i></div><small>Limit @snapshot.ChargeLimit%</small>}else{<h2>Not charging</h2><p>Charge limit @snapshot.ChargeLimit%</p>}</article>
        <article class="card"><p class="eyebrow">SOFTWARE</p><h2>@snapshot.SoftwareVersion</h2><p>Installed vehicle software</p><span class="pill">Fleet API</span></article>
        <article class="card"><p class="eyebrow">ESTIMATED RANGE</p><h2>@snapshot.EstimatedRangeMiles mi</h2><p>at @snapshot.StateOfCharge% state of charge</p></article>
    </section>
    <section class="timeline card"><div class="section-heading"><div><p class="eyebrow">FSD &amp; ACTIVITY</p><h2>History is not tracked yet</h2></div><span>Fleet Telemetry needed</span></div><p>FSD share, drives, charging history, and recent events require Fleet Telemetry ingestion and persistent storage. The values above come directly from the current vehicle-data response.</p></section>
}
